# ════════════════════════════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/owner_saas?schema=public"

# ════════════════════════════════════════════════════════════════════════════════
# FIREBASE ADMIN SDK (compartido con TODOS los sistemas del ecosistema)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# ════════════════════════════════════════════════════════════════════════════════
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com"
# En .env reemplazar saltos de línea con \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ════════════════════════════════════════════════════════════════════════════════
# APP
# ════════════════════════════════════════════════════════════════════════════════
NODE_ENV="development"
PORT=3000
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003"
FRONTEND_URL="http://localhost:3001"

# ════════════════════════════════════════════════════════════════════════════════
# EMAIL TRANSACCIONAL (para invitaciones — Resend recomendado)
# https://resend.com → API Keys → Create API Key
# ════════════════════════════════════════════════════════════════════════════════
RESEND_API_KEY=""
EMAIL_FROM="noreply@tudominio.com"