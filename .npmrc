# Aprobar scripts de build para dependencias que los requieren
# Necesario para pnpm 9+ que bloquea lifecycle scripts por defecto
enable-pre-post-scripts=true

# Dependencias que necesitan compilar bindings nativos o generar archivos
approve-builds[]=bcrypt
approve-builds[]=@prisma/engines
approve-builds[]=prisma
approve-builds[]=@nestjs/core
approve-builds[]=@firebase/util
approve-builds[]=protobufjs
approve-builds[]=unrs-resolver
